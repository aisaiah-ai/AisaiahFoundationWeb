# Aisaiah Foundation — Environment Variables
#
# This file is the single source of truth for what env vars exist.
# It is used by:
#   • developers — copy to .env.local for local dev
#   • scripts/bootstrap-secrets.sh — pushes values to GitHub secrets
#   • scripts/doctor.sh — verifies presence pre-deploy
#   • CI workflows — match these names against repo secrets
#
# To bootstrap from scratch, see BOOTSTRAP.md.

# ── Firebase (web SDK; baked into client bundle at build time) ───────────────
# Get these from: Firebase console → Project settings → Your apps → Web SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Cloudflare (deploy-time only — NEVER needed at runtime) ──────────────────
# Used by GitHub Actions to deploy to Pages and (optionally) provision DNS.
# Live in .env.cloudflare (gitignored), NOT .env.local.
# CLOUDFLARE_API_TOKEN=         # Custom token — see BOOTSTRAP.md for permissions
# CLOUDFLARE_ACCOUNT_ID=        # 32-char hex from CF dashboard right sidebar
# CLOUDFLARE_ZONE_ID=           # 32-char hex from the aisaiah.org zone overview

# ── How environments map to GitHub secrets ───────────────────────────────────
# .env.development  →  NEXT_PUBLIC_FIREBASE_*_DEV   (used by deploy-dev.yml)
# .env.production   →  NEXT_PUBLIC_FIREBASE_*_PROD  (used by deploy-prod.yml)
# .env.cloudflare   →  CLOUDFLARE_*                 (shared by both)
#
# One command syncs all three: ./scripts/bootstrap-secrets.sh all
