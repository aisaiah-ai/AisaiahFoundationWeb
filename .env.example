# Aisaiah Foundation — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# For development: use your Firebase dev project credentials
# For production: use your Firebase prod project credentials
# Firebase is optional — the site builds and runs without it,
# but the contact form will show a warning.

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# GitHub Actions Secrets (for CI/CD — not needed locally)
# -------------------------------------------------------
# CLOUDFLARE_API_TOKEN       — Cloudflare API token (Pages + DNS permissions)
# CLOUDFLARE_ACCOUNT_ID      — Cloudflare account ID
# CLOUDFLARE_ZONE_ID         — Cloudflare zone ID for aisaiah.org
#
# NEXT_PUBLIC_FIREBASE_*_DEV  — Firebase dev project credentials (6 vars)
# NEXT_PUBLIC_FIREBASE_*_PROD — Firebase prod project credentials (6 vars)
